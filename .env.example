# MAESTROMIND — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local

# ─── ANTHROPIC (côté SERVEUR uniquement — ne jamais exposer côté client) ───
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici

# ─── PDG PIN (hash SHA-256 du code PIN du tableau de bord PDG) ──────────────
# Par défaut : PIN = "123456"  →  hash = 8d969eef...
VITE_PDG_PIN_HASH=8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92

# ─── Stripe (paiements — à configurer en V2) ─────────────────────────────────
# VITE_STRIPE_PUBLIC_KEY=pk_live_...
